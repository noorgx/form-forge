{
  "base_image": "base.jpeg",
  "out_image": "out/filled.png",
  "font": "fonts/YourFont.ttf",
  "ink": [20, 20, 20],
  "default_size": 22,
  "fields": [
    { "name": "full_name", "type": "text", "box": [120, 80, 480, 110], "value": "" },

    { "name": "birth_date", "type": "date", "box": [120, 140, 320, 170],
      "parts": {
        "day":   { "box": [120, 140, 160, 170], "value": "" },
        "month": { "box": [170, 140, 210, 170], "value": "" },
        "year":  { "box": [220, 140, 300, 170], "value": "" }
      } },

    { "name": "gender", "type": "choice", "mark": "x", "selected": "",
      "options": [ { "key": "male",   "box": [120, 200, 140, 220] },
                   { "key": "female", "box": [200, 200, 220, 220] } ] },

    { "name": "id_number", "type": "digits", "box": [120, 250, 520, 282], "count": 14, "value": "" },

    { "name": "serial", "type": "text", "box": [400, 30, 540, 60], "value": "",
      "font": "fonts/YourStamp.otf", "color": "#b3001b" }
  ]
}
